# =============================================================================
# .gitignore — COVID-19 Data Analysis Project
# =============================================================================

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
.env/
.direnv/

# ── Environment variables (NEVER commit credentials) ─────────────────────────
.env

# ── Jupyter Notebook ──────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb~

# ── Raw data (large files — download via run.py) ──────────────────────────────
data/raw/owid-covid-data.csv

# ── Processed outputs (re-generated by the pipeline) ─────────────────────────
data/processed/covid_cleaned.csv
data/processed/india_covid.csv
data/processed/country_summary.csv
data/processed/analysis/
data/processed/sql_results/

# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── IDE / editor settings ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Tableau & Power BI workbooks (binary — store in separate release assets) ──
*.twb
*.twbx
*.pbix
*.pbip

# ── pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
