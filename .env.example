# ============================================================
# COVID-19 Data Analysis Pipeline - Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.
# ============================================================

# --- PostgreSQL Connection ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=covid19_analysis
DB_USER=postgres
DB_PASSWORD=postgres

# --- OWID Data Source URL ---
# Primary: GitHub raw CSV (full dataset, ~100MB)
OWID_CSV_URL=https://raw.githubusercontent.com/owid/covid-19-data/master/public/data/owid-covid-data.csv

# --- File Paths (relative to project root) ---
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
SQL_DIR=sql
